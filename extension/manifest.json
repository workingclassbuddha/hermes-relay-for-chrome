{
  "manifest_version": 3,
  "name": "Hermes Relay for Chrome",
  "short_name": "Hermes Relay",
  "version": "0.1.0",
  "description": "Browser extension for Hermes Agent by Nous Research: page context, continuity, tracked pages, and AI handoff.",
  "homepage_url": "https://github.com/workingclassbuddha/hermes-relay-for-chrome",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "contextMenus",
    "sidePanel"
  ],
  "commands": {
    "capture-page": {
      "suggested_key": {
        "default": "Alt+Shift+H"
      },
      "description": "Capture the current page with Hermes"
    },
    "build-context": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Build Hermes context for the current page"
    },
    "inject-context": {
      "suggested_key": {
        "default": "Alt+Shift+I"
      },
      "description": "Inject the latest Hermes context into the active chat"
    }
  },
  "host_permissions": [
    "http://127.0.0.1:8642/*",
    "http://localhost:8642/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Hermes Relay for Chrome",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "content/chat.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
